{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "YOUR_ANTHROPIC_API_KEY",
    "ANTHROPIC_BASE_URL": "https://api.anthropic.com",
    "NOTION_TOKEN": "YOUR_NOTION_INTEGRATION_TOKEN",
    "NOTION_PARENT_PAGE_ID": "YOUR_AI_SUMMARY_PAGE_ID",
    "WEEKLY_TODO_PAGE_ID": "YOUR_WEEKLY_TODO_PAGE_ID"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:\\Users\\YOUR_USERNAME\\.claude\\hooks\\summarize_conversation.py\""
          }
        ]
      }
    ]
  }
}
